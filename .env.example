# ─── LOCAL DEVELOPMENT (PostgreSQL di komputer sendiri) ───
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smash_arena
DB_USER=postgres
DB_PASSWORD=yourpassword

# ─── PRODUCTION (Railway) ───
# Railway otomatis menyediakan DATABASE_URL saat kamu provision PostgreSQL.
# Jika DATABASE_URL terisi, kode akan memakainya (dengan SSL otomatis) dan
# mengabaikan DB_HOST/DB_PORT/dst di atas.
# DATABASE_URL=postgresql://user:password@host:port/database

# JWT
JWT_SECRET=ganti_dengan_string_acak_yang_panjang_dan_aman
JWT_EXPIRES_IN=7d

# Server
PORT=3000
NODE_ENV=development

# File Upload
UPLOAD_PATH=./uploads/payments
MAX_FILE_SIZE=5242880

# URLs
# BASE_URL = alamat backend ini sendiri (dipakai untuk membentuk link gambar bukti bayar)
BASE_URL=http://localhost:3000
# FRONTEND_URL = alamat frontend (dipakai untuk whitelist CORS). Bisa lebih dari satu,
# dipisah koma, contoh: https://app.netlify.app,https://preview-123.netlify.app
FRONTEND_URL=http://localhost:5173
